datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Author {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
}

model Category {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
}

model Post {
  id             Int             @id @default(autoincrement())
  title          String
  slug           String          @unique
  description    String
  content        Json
  status         PostStatus

  authorId       Int
  categoryId     Int

  author         Author          @relation(fields: [authorId], references: [id])
  category       Category        @relation(fields: [categoryId], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  publishedAt    DateTime?
  archivedAt     DateTime?

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}