generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AuthorStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model Author {
  id        Int          @id @default(autoincrement())
  name      String
  bio       String?
  avatarUrl String?
  status    AuthorStatus @default(INACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userId    Int
  user      User @relation(fields: [userId], references: [id])

  posts     Post[]

  @@index([userId])
}
model User {
  id                Int        @id @default(autoincrement())
  name              String
  email             String     @unique
  passwordHash      String
  status            UserStatus
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  passwordChangedAt DateTime?  @default(now())
  role              UserRole   @default(AUTHOR)
  authors           Author[]
}

model Category {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  color     String
  posts     Post[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  slug        String     @unique
  description String
  content     String
  status      PostStatus
  authorId    Int
  categoryId  Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  archivedAt  DateTime?
  author      Author     @relation(fields: [authorId], references: [id])
  category    Category   @relation(fields: [categoryId], references: [id])

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  AUTHOR
  EDITOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}
