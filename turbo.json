{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"], 
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false
    },
    "test": {
      "dependsOn": ["build"], 
      "outputs": ["test-results/**"]
    },
    "lint": {
      "outputs": []
    }
  },
  "globalDependencies": ["tsconfig.json", "package.json"]
}